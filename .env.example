# Root – Hardhat (optional, for deploy to Sepolia)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# PRIVATE_KEY=your_ethereum_private_key

# Backend – create backend/.env
# IPFS_URL=http://127.0.0.1:5001
# PORT=3001

# Frontend – create frontend/.env (required for contract + API)
# VITE_CONTRACT_ADDRESS=0x...   # from npm run deploy:hardhat or deploy:local
# VITE_API_URL=                 # leave empty if using Vite proxy to backend
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
